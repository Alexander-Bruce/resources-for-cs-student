<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="backend.dao.UserDao">

    <insert id="insert" parameterType="backend.model.User" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO `user` (username, password)
        VALUES (#{username}, #{password})
    </insert>

    <select id="getAllUsers" resultType="backend.model.User">
        SELECT *
        FROM `user`
    </select>
</mapper>