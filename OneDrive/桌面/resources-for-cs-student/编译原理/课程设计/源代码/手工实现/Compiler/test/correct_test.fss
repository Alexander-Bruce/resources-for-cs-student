# correct_all_commands.fss

# --- 初始化阶段 ---
MKDIR test_environment  # 创建测试环境目录
CD test_environment  # 进入测试环境
PWD  # 显示当前工作目录

# --- MKDIR 测试 ---
MKDIR dir1  # 创建目录1
MKDIR dir2  # 创建目录2
MKDIR -p nested/deeply/dir3  # 递归创建嵌套目录

# --- WRITE 和 READ 测试 ---
WRITE dir1/file1.txt "Hello from FSS!"  # 写入文件1
WRITE "dir1/file with spaces.txt" "文件名包含空格的测试文件"  # 写入带空格文件名
READ dir1/file1.txt  # 读取文件1
READ "dir1/file with spaces.txt"  # 读取带空格文件名

WRITE -a dir1/file1.txt "\n追加的第二行内容"  # 追加内容
READ dir1/file1.txt   # 读取追加后的文件

# --- CHMOD 测试 ---
CHMOD 444 dir1/file1.txt  # 修改文件权限为666
LS -l dir1  # 查看目录本身权限
CHMOD 777 dir1/file1.txt

# --- LS 测试 ---
LS -la dir1 # 长格式显示所有文件

# --- CP 测试 ---
# 复制文件到新文件
CP dir1/file1.txt dir1/file1_copy.txt  # 复制文件
READ dir1/file1_copy.txt  # 读取复制后的文件

# 复制文件到目录
CP "dir1/file with spaces.txt" dir2/  # 复制带空格文件到目录
LS -l dir2  # 查看目录内容

# 复制多个文件到目录
MKDIR dir3  # 创建多文件复制目标目录
CP dir1/file1.txt "dir1/file with spaces.txt" dir3/  # 复制多个文件
LS -l dir3  # 查看目标目录

# 复制目录(需要-r选项)
CP -rv dir1 dir4  # 递归复制目录，使用-v显示详细信息
LS dir4  # 列出复制后的目录

# --- MV 测试 ---
MV dir1/file1_copy.txt dir1/file1_renamed.txt  # 重命名文件
LS dir1# 查看结果

# 移动文件到目录
MV dir1/file1_renamed.txt dir2/  # 移动文件到目录
LS dir2  # 查看目标目录

# 移动并重命名目录
MV dir4/ dir5/  # 移动并重命名目录
LS  # 查看结果

# 移动多个文件到目录
MKDIR dir6  # 创建多文件移动目标目录
# 创建要移动的源文件
WRITE mv_source1.txt "移动源文件1"
WRITE mv_source2.txt "移动源文件2"
WRITE dir6/mv_source_dir6.txt "dir6源文件1"
MV -fv mv_source1.txt mv_source2.txt dir6/  # 移动多个文件
LS dir6  # 查看目标目录

# --- RM 测试 ---
# 删除文件
mkdir dir7
write dir7/file1.txt "内容"
write dir7/file2.txt "内容"
RM dir7/file1.txt  # 删除文件
LS dir7  # 查看结果

# 为-f测试
write dir7/file1.txt "内容"
RM -f non_existent_for_rm_f.txt  # -f选项对不存在的文件不应报错

# 删除空目录
MKDIR empty_dir_for_rm  # 创建空目录
RM empty_dir_for_rm  # 删除空目录
LS  # 查看结果

# 递归删除多文件
RM -rf dir2 dir3 dir4 dir5 dir6 dir7
LS  # 查看结果

# --- SOURCE 测试 ---
# 创建要导入的小脚本
CD ..
SOURCE test/external_script.fss  # 导入脚本
READ test/external_script.fss 

# --- EXIT 测试 ---
EXIT  # 退出
# EXIT之后的命令不应被执行
PWD
MKDIR this_should_not_be_created